{
  "manifest_version": 3,
  "name": "PhishGuard Browser Threat & Link Risk Analyzer",
  "version": "1.1.0",
  "description": "Defensive browser extension that automatically scores phishing risk, explains warning signs, and helps users review suspicious links safely.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "PhishGuard",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["riskEngine.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
