{
  "manifest_version": 3,
  "name": "Browser Phishing Risk Analyzer",
  "version": "1.0.0",
  "description": "Analyzes the active page URL for common phishing risk indicators and explains the findings.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["riskEngine.js", "content.js"]
    }
  ]
}
